# ---- Server ----
PORT=8787
# Your frontend origin. In production set this to your Netlify URL.
ALLOWED_ORIGIN=http://localhost:5173

# ---- Privy (App Secret is BACKEND ONLY) ----
PRIVY_APP_ID=cmqpf55ja00jk0cjmf6lfqqdq
# Paste the NEW App Secret you just regenerated. Never commit this file with a real value.
PRIVY_APP_SECRET=paste_your_new_regenerated_app_secret_here

# ---- Anthropic (Claude) ----
ANTHROPIC_API_KEY=paste_your_anthropic_api_key_here
# Balanced default. Cheaper: claude-haiku-4-5. Most capable: claude-opus-4-8.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Resonance heuristic ----
RESONANCE_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,DOGEUSDT

# ---- X (Twitter) API for profile follower counts (OPTIONAL) ----
# Pay-per-use in 2026 (~$0.01 per user lookup). Create an app at developer.x.com,
# generate an app-only Bearer Token, and load a little credit. Leave blank to
# disable follower counts (the rest of the profile still works).
X_BEARER_TOKEN=
# Override only if X fully migrates the API host (default api.twitter.com).
X_API_BASE=https://api.twitter.com

# ---- Alchemy (multi-chain wallet token holdings) ----
# Free key from alchemy.com. Backend only, never the frontend. Enable the
# networks you want (Ethereum, Base, Arbitrum, Optimism, Polygon) for this
# key/app in the Alchemy dashboard.
ALCHEMY_API_KEY=
# Optional: limit which chains to read (comma separated).
# Default reads all of: ethereum,base,arbitrum,optimism,polygon
HOLDINGS_CHAINS=

# ---- Live market data (Binance USD-M Futures, proxied; no API key needed) ----
# Swap the base if Binance is geo-blocked from where the backend runs (e.g. a
# mirror or your own proxy). Default is the public Binance Futures API.
BINANCE_FAPI_BASE=https://fapi.binance.com
# Comma list of symbols that get the heavy positioning / order-flow / OI metrics
# (real Resonance / Crowding / Order-flow / Agent-activity). Price, funding and
# volume are already live for ALL pairs from two bulk calls. Leave empty for the
# built-in default set of majors.
MARKET_SYMBOLS=
# How long (ms) to cache a market snapshot before refetching. Default 20000.
MARKET_CACHE_MS=20000
# Real liquidation feed via Binance WebSocket: auto (on if your Node has a global
# WebSocket, i.e. Node 21+), on, or off (always estimate). Default auto.
MARKET_LIQ_WS=auto
# WebSocket base for the liquidation stream (rarely needs changing).
BINANCE_WS_BASE=wss://fstream.binance.com/ws

# --- Coinalyze (FREE real liquidation data, recommended) ---
# Coinalyze offers a genuinely free API. Create a free account and generate
# a key at https://coinalyze.net/account/api-key/ (40 calls/min). It serves real
# liquidation data over HTTPS, so it works even where Binance is geo-blocked.
# Gives hourly long/short totals + history (no per-price breakdown).
COINALYZE_API_KEY=
COINALYZE_EXCHANGE_CODE=A
COINALYZE_API_BASE=https://api.coinalyze.net/v1
COINALYZE_CACHE_MS=12000

# --- FVG Radar (Fair Value Gap detector) ---
# Uses Binance klines (no key); falls back to Coinalyze OHLCV (free key above).
FVG_CACHE_MS=30000
SYMBOL_CACHE_MS=20000
